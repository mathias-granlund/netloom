# netloom per-profile server configuration
#
# Copy this file to:
#   ~/.config/netloom/plugins/clearpass/profiles/prod.env
#
# This file contains non-secret settings for one profile.
# Shared plugin defaults should live in `defaults.env`.
# Secrets should live in `credentials/<profile>.env`.
# Use `netloom load clearpass` first so `~/.config/netloom/config.env` points at
# the active plugin.

# -----------------------------------------------------------------------------
# Required connection settings for this profile
# -----------------------------------------------------------------------------

NETLOOM_SERVER=clearpass-prod.example.com:443

# -----------------------------------------------------------------------------
# Optional overrides for this profile
# -----------------------------------------------------------------------------

NETLOOM_VERIFY_SSL=true
NETLOOM_TIMEOUT=15
NETLOOM_GRANT_TYPE=client_credentials

# Optional secure-secret reference if you want it in the profile file instead
# of credentials/<profile>.env.
# NETLOOM_CLIENT_SECRET_REF=prod/client-secret

# Optional plaintext fallback if keychain lookup fails.
# NETLOOM_CLIENT_SECRET=prod-client-secret

# Optional direct token overrides.
# NETLOOM_API_TOKEN=your-prod-access-token

# Optional token-file overrides.
# NETLOOM_API_TOKEN_FILE=/home/you/.config/netloom/prod-token.json

# Optional output defaults.
NETLOOM_DATA_FORMAT=json

# NETLOOM_CSV_FIELDNAMES=id,name

NETLOOM_CONSOLE=false
NETLOOM_ENCRYPT_SECRETS=true

# Optional logging defaults.
NETLOOM_LOG_LEVEL=INFO
