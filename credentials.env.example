# netloom per-profile credentials
#
# Copy this file to:
#   ~/.config/netloom/plugins/clearpass/credentials/prod.env
#
# Keep this file user-specific and do not commit real secrets.

# -----------------------------------------------------------------------------
# Required OAuth credentials for this profile
# -----------------------------------------------------------------------------

NETLOOM_CLIENT_ID=prod-client-id

# Preferred: resolve the secret from the OS keychain at runtime.
#   service:  netloom/clearpass
#   username: prod/client-secret
NETLOOM_CLIENT_SECRET_REF=prod/client-secret

# Optional plaintext fallback when no keychain ref is configured, or when a
# configured keychain lookup fails.
# NETLOOM_CLIENT_SECRET=prod-client-secret

# Optional aliases if you prefer username/password naming:
# NETLOOM_USERNAME=prod-client-id
# NETLOOM_PASSWORD=prod-client-secret
