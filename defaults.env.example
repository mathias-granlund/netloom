# netloom plugin defaults
#
# Copy this file to:
#   ~/.config/netloom/plugins/clearpass/defaults.env
#
# This file holds the active profile plus plugin-wide fallback values that
# apply unless a per-profile file overrides them.

# The currently selected profile for this plugin.
NETLOOM_ACTIVE_PROFILE=prod

# Optional shared defaults for all profiles under this plugin.
NETLOOM_HTTPS_PREFIX=https://
NETLOOM_VERIFY_SSL=true
NETLOOM_TIMEOUT=15
NETLOOM_GRANT_TYPE=client_credentials
NETLOOM_DATA_FORMAT=json
NETLOOM_CONSOLE=false
NETLOOM_ENCRYPT_SECRETS=true
NETLOOM_LOG_LEVEL=INFO
NETLOOM_VERIFY_SSL=true
NETLOOM_LOG_TO_FILE=true

# Optional token defaults.
# NETLOOM_API_TOKEN=shared-access-token
# NETLOOM_API_TOKEN_FILE=/home/you/.config/netloom/shared-token.json

# Optional storage path overrides remain global and are usually better set as
# plain environment variables if needed:
# NETLOOM_CACHE_DIR=/custom/cache/path
# NETLOOM_STATE_DIR=/custom/state/path
# NETLOOM_OUT_DIR=/custom/response/output/path
# NETLOOM_APP_LOG_DIR=/custom/app/log/path
